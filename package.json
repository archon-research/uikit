{
  "name": "@archon-research/uikit",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.17.0",
  "workspaces": [
    "packages/tsconfig",
    "packages/oxlint-config",
    "packages/oxfmt-config",
    "packages/agent-marketplace",
    "packages/design-system",
    "packages/charting",
    "packages/http-client-core",
    "packages/http-client-react",
    "packages/mcp-relay",
    "packages/webmcp",
    "packages/mcp-connect",
    "packages/uikit-preview",
    "packages/uikit-cli"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type:check": "npm run type:check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && npm run cf:test --workspace @archon-research/uikit-preview",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "preview:build": "npm run build --workspace @archon-research/uikit-preview",
    "preview:dev": "npm run dev --workspace @archon-research/uikit-preview",
    "uikit:register-links": "uikit-cli register",
    "install-hooks": "lefthook install",
    "hooks:pre-commit": "lefthook run pre-commit",
    "prepare": "npm run prepare --workspaces --if-present",
    "release:dry-run": "semantic-release --dry-run --no-ci -p @semantic-release/commit-analyzer -p @semantic-release/release-notes-generator -p @semantic-release/exec -p @semantic-release/git",
    "release:run": "semantic-release"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260615.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "lefthook": "2.1.9",
    "semantic-release": "25.0.5"
  },
  "optionalDependencies": {
    "@oxfmt/binding-linux-x64-gnu": "0.54.0",
    "@oxlint/binding-linux-x64-gnu": "1.69.0"
  }
}
