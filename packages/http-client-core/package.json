{
  "name": "@archon-research/http-client-core",
  "version": "0.1.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "uikit-openapi-generate": "./bin/generate-openapi.mjs"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "type:check": "[ ! -f tsconfig.json ] || tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}
