{
  "extends": "@archon-research/tsconfig/node",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "types": ["node"],
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "declarationMap": false,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "bin/**/*.ts"]
}
