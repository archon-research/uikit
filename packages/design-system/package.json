{
  "name": "@archon-research/design-system",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./recipes": {
      "types": "./dist/recipes/index.d.ts",
      "default": "./src/recipes/index.ts"
    },
    "./panda-preset": {
      "types": "./dist/panda-preset.d.ts",
      "default": "./src/panda-preset.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "type:check": "tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@ark-ui/react": "^5.25.1",
    "@pandacss/dev": "^1.9.1",
    "@tanstack/react-table": "^8.20.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@archon-research/oxlint-config": "*",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.64.0"
  }
}
