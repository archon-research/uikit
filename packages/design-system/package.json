{
  "name": "@archon-research/design-system",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./recipes": {
      "types": "./src/recipes/index.d.ts",
      "default": "./src/recipes/index.ts"
    },
    "./panda-preset": {
      "types": "./src/panda-preset.d.ts",
      "default": "./src/panda-preset.ts"
    }
  },
  "scripts": {
    "type:check": "tsgo -p tsconfig.json --noEmit",
    "lint": "npm exec --yes -- oxlint -c oxlint.config.ts src",
    "lint:fix": "npm exec --yes -- oxlint -c oxlint.config.ts --fix src"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@ark-ui/react": "^5.25.1",
    "@pandacss/dev": "^1.9.1",
    "@tanstack/react-table": "^8.20.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@archon-research/oxlint-config": "*",
    "oxlint": "^1.64.0"
  }
}
