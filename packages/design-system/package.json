{
  "name": "@archon-research/design-system",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./recipes": {
      "types": "./dist/recipes/index.d.ts",
      "default": "./dist/recipes/index.js"
    },
    "./panda-preset": {
      "types": "./dist/panda-preset.d.ts",
      "default": "./dist/panda-preset.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "type:check": "tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint -c oxlint.config.ts src",
    "lint:fix": "oxlint -c oxlint.config.ts --fix src",
    "format": "oxfmt -c oxfmt.config.ts --write src",
    "format:check": "oxfmt -c oxfmt.config.ts --check src"
  },
  "dependencies": {
    "@ark-ui/react": "5.36.2",
    "@pandacss/dev": "1.11.1",
    "@tanstack/react-table": "8.21.3",
    "lucide-react": "1.18.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@archon-research/oxlint-config": "*",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0"
  }
}
