{
  "name": "@archon-research/http-client-react",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "type:check": "tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src"
  },
  "dependencies": {
    "@archon-research/http-client-core": "*",
    "@tanstack/react-query": "^5.96.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "oxfmt": "^0.48.0",
    "oxlint": "^1.64.0"
  }
}
