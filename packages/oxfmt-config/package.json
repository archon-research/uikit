{
  "name": "@archon-research/oxfmt-config",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist",
    "index.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "type:check": "tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint index.ts",
    "lint:fix": "oxlint --fix index.ts",
    "format": "oxfmt --write index.ts",
    "format:check": "oxfmt --check index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "oxfmt": "^0.48.0",
    "oxlint": "^1.64.0"
  }
}
