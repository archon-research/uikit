{
  "name": "@archon-research/oxlint-config",
  "version": "0.1.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "files": [
    "base.mjs",
    "react.mjs"
  ],
  "scripts": {
    "type:check": "[ ! -f tsconfig.json ] || tsgo -p tsconfig.json --noEmit"
  },
  "exports": {
    "./base": "./base.mjs",
    "./react": "./react.mjs"
  }
}
