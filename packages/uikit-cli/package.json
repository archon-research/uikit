{
  "name": "@archon-research/uikit-cli",
  "type": "module",
  "description": "CLI for managing local uikit package linking in consumer workspaces",
  "scripts": {
    "build": "tsgo -b && npm run wrapper",
    "wrapper": "./scripts/create-wrapper.sh",
    "clean": "rm -rf dist",
    "type:check": "tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint -c oxlint.config.ts src",
    "lint:fix": "oxlint -c oxlint.config.ts --fix src",
    "format": "oxfmt -c oxfmt.config.ts --write src",
    "format:check": "oxfmt -c oxfmt.config.ts --check src",
    "prepare": "npm run build"
  },
  "bin": {
    "uikit-cli": "./dist/cli.sh"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0"
  },
  "devDependencies": {
    "@archon-research/tsconfig": "*",
    "@types/node": "24.12.4"
  },
  "files": [
    "dist"
  ]
}
