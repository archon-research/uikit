{
  "name": "uikit-agent-marketplace",
  "description": "Reusable UI-focused skills and specialist agents for Claude Code.",
  "author": {
    "name": "Archon Research"
  },
  "lspServers": {
    "oxlint": {
      "command": "oxlint",
      "args": [
        "--lsp"
      ],
      "extensionToLanguage": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript",
        ".cjs": "javascript"
      }
    }
  }
}
