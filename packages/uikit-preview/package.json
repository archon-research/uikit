{
  "name": "@archon-research/uikit-preview",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash ./scripts/build-preview.sh",
    "clean": "rm -rf dist",
    "lint": "oxlint -c oxlint.config.ts src",
    "lint:fix": "oxlint -c oxlint.config.ts --fix src",
    "format": "oxfmt -c oxfmt.config.ts --write src",
    "format:check": "oxfmt -c oxfmt.config.ts --check src",
    "type:check": "npm run generate && tsgo -p tsconfig.json --noEmit",
    "generate": "panda codegen --clean --config panda.config.ts && panda cssgen --config panda.config.ts --outfile styled-system/styles.css && panda spec --config panda.config.ts --outdir ./static/tokens/spec",
    "dev": "npm run generate && ladle serve --host 0.0.0.0 --port 61000",
    "snapshot:serve": "ladle preview --outDir dist --host 127.0.0.1 --port 61000",
    "snapshot:test": "playwright test",
    "snapshot:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@archon-research/design-system": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@archon-research/oxlint-config": "*",
    "@archon-research/tsconfig": "*",
    "@ladle/react": "^5.1.1",
    "@pandacss/dev": "^1.10.0",
    "@playwright/test": "^1.54.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.64.0"
  }
}
