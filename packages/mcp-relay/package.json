{
  "name": "@archon-research/mcp-relay",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "type:check": "tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint -c oxlint.config.ts src",
    "lint:fix": "oxlint -c oxlint.config.ts --fix src",
    "format": "oxfmt -c oxfmt.config.ts --write src",
    "format:check": "oxfmt -c oxfmt.config.ts --check src",
    "test": "vitest run"
  },
  "devDependencies": {
    "@archon-research/oxfmt-config": "*",
    "@archon-research/tsconfig": "*",
    "@types/node": "^24.7.2",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "vitest": "^3.2.4"
  }
}
